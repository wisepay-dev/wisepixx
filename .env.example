# App
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=change-me-with-openssl-rand-base64-32
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ROOT_DOMAIN=wisepix.online
NEXT_PUBLIC_SHOW_MOCKS=false

# Database
# Supabase Postgres connection string used by Prisma.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wisepix?schema=public

# Supabase Storage / browser client
# Required when uploads/storage are enabled.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only key for privileged storage/admin operations. Never expose this in client code.
SUPABASE_SERVICE_ROLE_KEY=

# Discord OAuth and bot
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_GUILD_ID=

# Miuse
MIUSE_BASE_URL=https://api.miuse.app/v1/api
MIUSE_PLATFORM_TOKEN=
MIUSE_WEBHOOK_SECRET=
MIUSE_OWNER_WALLET_ID=
MIUSE_BALANCE_PATH_TEMPLATE=/wallets/{wallet_id}/balance

# Cron
CRON_SECRET=

# Crypto
ENCRYPTION_KEY=change-me-32-bytes-base64

# Push notifications
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
